rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model where all personal resume data is siloed 
     * within a user's unique path (/users/{userId}). Authorization is determined by comparing 
     * the authenticated user's UID against the path wildcards, ensuring "Authorization Independence" 
     * without the need for expensive cross-document lookups.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: The root for all user-owned data.
     *   - /userProfile: Meta-information about the user's resume activity.
     *   - /resumes/{resumeId}: Individual resume documents.
     *     - /contactInformation, /workExperiences, /educations, /skills: Detailed resume sections.
     * - /templates: Globally accessible, read-only resume designs.
     *
     * KEY SECURITY DECISIONS:
     * 1. Path-Based Authorization: We rely on the {userId} wildcard in the path to verify ownership.
     * 2. Relational Integrity: On creation, we enforce that internal foreign keys (like resumeId or userProfileId) 
     *    match the document's path to prevent data being "orphaned" or misattributed.
     * 3. Prototyping Flexibility: We do not enforce strict schemas for content fields (strings, dates, etc.), 
     *    allowing the frontend to evolve rapidly while keeping the data access secure.
     * 4. Immutable Links: Critical relational fields are made immutable during updates.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the user's root profile document.
     * @path /users/{userId}/userProfile
     * @allow User 'abc' to (get) /users/abc/userProfile
     * @deny User 'xyz' to (update) /users/abc/userProfile
     * @principle Restricts access to a user's own data tree and validates path consistency.
     */
    match /users/{userId}/userProfile {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for individual resumes created by a user.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow User 'abc' to (create) a resume under /users/abc/resumes/123
     * @deny User 'abc' to (create) a resume where userProfileId is 'xyz'
     * @principle Enforces document ownership and relational integrity for parent links.
     */
    match /users/{userId}/resumes/{resumeId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userProfileId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userProfileId == resource.data.userProfileId;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for contact information associated with a specific resume.
       * @path /users/{userId}/resumes/{resumeId}/contactInformation/{id}
       * @allow Owner 'abc' to (create) contact info for their own resume '123'
       * @deny User 'abc' to (list) contact info for user 'xyz'
       * @principle Inherits authorization from the parent path and validates resume linkage.
       */
      match /contactInformation/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.resumeId == resumeId;
        allow update: if isExistingOwner(userId) && request.resource.data.resumeId == resource.data.resumeId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for work experience entries.
       */
      match /workExperiences/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.resumeId == resumeId;
        allow update: if isExistingOwner(userId) && request.resource.data.resumeId == resource.data.resumeId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for education entries.
       */
      match /educations/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.resumeId == resumeId;
        allow update: if isExistingOwner(userId) && request.resource.data.resumeId == resource.data.resumeId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for skill entries.
       */
      match /skills/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.resumeId == resumeId;
        allow update: if isExistingOwner(userId) && request.resource.data.resumeId == resource.data.resumeId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for resume templates available to all users.
     * @path /templates/{templateId}
     * @allow Any user (including anonymous) to (get) a template.
     * @deny Any user to (create, update, or delete) a template.
     * @principle Public read access for system resources with strictly denied writes.
     */
    match /templates/{templateId} {
      allow get, list: if true;
      // CRITICAL: The 'Template' entity is system-managed and lacks an 'ownerId'. 
      // User writes are disabled to maintain template integrity.
      allow create, update, delete: if false; 
    }
  }
}